# Cloud API configuration (services/api). Copy to .env for local dev.
# NEVER commit a real .env — secrets stay out of the repo and out of the desktop
# app entirely (ADR-0001).

# Port the local API dev server binds to.
API_PORT=8787

# --- Backend-only secrets (added in their respective issues) ---
# These belong ONLY to services/api. They must never reach apps/desktop.
# DATABASE_URL=postgres://...
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# LICENSE_SIGNING_KEY=...   # ed25519 private seed (base64/hex), backend only
